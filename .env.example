# ── App (VITE_ vars are baked into the frontend bundle) ─────────────────────

# Supabase project credentials (dashboard → Settings → API). Leave unset to
# run in local demo mode (browser localStorage, seeded with sample pieces).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# WhatsApp number for the "Enquire on WhatsApp" button, in international
# format without + or spaces, e.g. 919876543210
VITE_WHATSAPP_NUMBER=919999999999

# Hidden email of the single admin account (the login screen only asks for a
# passcode; this is the account it belongs to). The default is fine.
VITE_ADMIN_EMAIL=admin@manjrees.local

# Admin passcode for LOCAL DEMO MODE ONLY. In Supabase mode the passcode is
# set with `npm run admin:create -- <passcode>` instead (see below).
VITE_DEMO_ADMIN_PIN=1234

# OPTIONAL, LOCAL DEV ONLY: lets the "Suggest with AI" button call Gemini
# directly under `npm run dev` (which has no /api runtime). NEVER set this in
# Vercel — a VITE_ key ships in the public bundle. In production the key
# lives server-side as GEMINI_API_KEY (below / in Vercel).
VITE_GEMINI_API_KEY=

# ── Server-side only (NEVER expose these in the frontend) ───────────────────

# Powers the /api/generate serverless function ("Suggest with AI").
# Set this in Vercel → Settings → Environment Variables.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# For `npm run db:migrate`: the "Session pooler" connection string from the
# Supabase dashboard (Connect → URI), including the database password.
SUPABASE_DB_URL=

# For `npm run admin:create`: dashboard → Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=
