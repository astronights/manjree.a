# Supabase project credentials. Leave unset to run in local demo mode
# (data stored in the browser's localStorage, seeded with sample pieces).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin PIN for local demo mode only. In Supabase mode the admin signs in
# with a Supabase Auth email/password instead.
VITE_DEMO_ADMIN_PIN=1234

# WhatsApp number for the "Enquire on WhatsApp" button, in international
# format without + or spaces, e.g. 919876543210
VITE_WHATSAPP_NUMBER=919999999999
